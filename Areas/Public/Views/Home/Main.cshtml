                    <p class="card-title">Sales</p>
                    <p>The showing of sales through automated
                        graph and charts for visualizing revenues
                        and sales essential in identifying patterns to
                        make informed decisions about the current
                        financial situation.
                    </p>
                </div>
            </div>
        </div>
    </div>

    <!-- SERVICES -->
    <div class="services main-subsection-item" id="services">
        <p class="services-title">Everything you need in one place</p>
        <div class="services-item-con">

            <div class="services-item">
                <div class="services-img">
                    <img src="~/img/transaction.png">
                </div>


                <div class="services-description">
                    <p class="services-head">Transactions</p>
                    <p class="services-generate">Records transaction and their description</p>
                </div>
            </div>

            <div class="services-item">
                <div class="services-img">
                    <img src="~/img/reports.png">
                </div>

                <div class="services-description"> 
                    <p class="services-head">Reports</p>
                    <p class="services-generate">Generate finance summaries and analysis</p>
                </div>
            </div>

            <div class="services-item">
                <div class="services-img">
                    <img src="~/img/dashboard.png">
                </div>

                <div class="services-description">
                    <p class="services-head">dashboard</p>
                    <p class="services-generate">A quick overview of your financial performance</p>
                </div>
            </div>
            
        </div>
        
    </div>

    <!-- PRICING & PLANS -->
    <div class="price main-subsection-item" id="price">
        <div class="price-container">
            <div class="price-title">
                <p class="affordable-para price-text">Affordable Price, Just for You</p>
                <p class="prices-para price-text">Prices according just for your needs</p>
            </div>

            <div class="price-card-con">
                <div class="price-card">
                    <div class="price-starter-title">
                        <p class="starter-para">Starter</p>
                        <p class="before-para">Before ₱2,500</p>
                    </div>
                    <div class="price-now-title">
                        <p class="now-para">Now</p>
                        <p class="onefive-para">₱1,500</p>
                        <p class="permonth-para">per month</p>
                    </div>
                    <div class="price-save">
                        <p class="save-para">Save ₱3,000 over 3 months</p>
                        <p class="preffered-para">Preferred for beginners, new
                            business, and personal user
                        </p>
                    </div>
                </div>
            </div>

            <div class="price-getStarted">
                <button class="getStarted-btn primary-btn"><a asp-controller="Account" asp-action="SignUp">Get Started</a></button>
            </div>
        </div>
    </div>

</div>



