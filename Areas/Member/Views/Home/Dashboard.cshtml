@{
    // HEADER INFO
    ViewData["Title"] = "Dashboard";
    ViewData["Description"] = "Overview of your financial performance";
    ViewData["Page"] = "dashboard";
}

<div class="dashboard">
    <div class="dashboard-cards-con">

        <div class="card">
            <div class="card-head">
                <p>Total Income</p>

                <div class="card-icon-con">    
                    <div class="card-icon increasedIncome increase">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640"><path class="income" d="M342.6 73.4c-12.5-12.5-32.8-12.5-45.3 0l-160 160c-12.5 12.5-12.5 32.8 0 45.3s32.8 12.5 45.3 0L288 173.3V544c0 17.7 14.3 32 32 32s32-14.3 32-32V173.3l105.4 105.4c12.5 12.5 32.8 12.5 45.3 0s12.5-32.8 0-45.3l-160-160z"/></svg>
                    </div>

                    <div class="card-icon decreasedIncome decrease">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640"><path d="M297.4 566.6C309.9 579.1 330.2 579.1 342.7 566.6L502.7 406.6C515.2 394.1 515.2 373.8 502.7 361.3C490.2 348.8 469.9 348.8 457.4 361.3L352 466.7L352 96C352 78.3 337.7 64 320 64C302.3 64 288 78.3 288 96L288 466.7L182.6 361.3C170.1 348.8 149.8 348.8 137.3 361.3C124.8 373.8 124.8 394.1 137.3 406.6L297.3 566.6z"/></svg>
                    </div>
                </div>
            </div>

            <div class="card-details">
                <p class="card-details-value income financialValue">₱<span id="income"></span></p>
                <p class="card-details-description" >From all transactions</p>
            </div>
        </div>

        <div class="card">
            <div class="card-head">
                <p>Total Expense</p>

                <div class="card-icon-con">
                    <div class="card-icon increasedExpense decrease">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640"><path class="expense" d="M342.6 73.4c-12.5-12.5-32.8-12.5-45.3 0l-160 160c-12.5 12.5-12.5 32.8 0 45.3s32.8 12.5 45.3 0L288 173.3V544c0 17.7 14.3 32 32 32s32-14.3 32-32V173.3l105.4 105.4c12.5 12.5 32.8 12.5 45.3 0s12.5-32.8 0-45.3l-160-160z"/></svg>
                    </div>

                    <div class="card-icon decreasedExpense increase">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640"><path d="M297.4 566.6C309.9 579.1 330.2 579.1 342.7 566.6L502.7 406.6C515.2 394.1 515.2 373.8 502.7 361.3C490.2 348.8 469.9 348.8 457.4 361.3L352 466.7L352 96C352 78.3 337.7 64 320 64C302.3 64 288 78.3 288 96L288 466.7L182.6 361.3C170.1 348.8 149.8 348.8 137.3 361.3C124.8 373.8 124.8 394.1 137.3 406.6L297.3 566.6z"/></svg>
                    </div>
                </div>
            </div>

            <div class="card-details">
                <p class="card-details-value expense">₱<span id="expense"></span></p>
                <p class="card-details-description" >Over <span id="expenseStatement"></span>% greater than income</p>
            </div>
        </div>

        <div class="card">
            <div class="card-head">
                <p>Net Profit</p>

                <div class="card-icon-con">
                    <div class="card-icon increasedNetProfit">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640"><path class="trend-up" d="M416 224a32 32 0 1 1 0-64h160c18 0 32 14 32 32v160a32 32 0 1 1-64 0v-83L375 439a32 32 0 0 1-46 0L224 333 87 471a32 32 0 0 1-46-46l160-160c13-12 33-12 46 0l105 106 147-147h-83z"/></svg>
                    </div>

                    <div class="card-icon decreasedNetProfit decrease">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640"><path d="M416 416C398.3 416 384 430.3 384 448C384 465.7 398.3 480 416 480L576 480C593.7 480 608 465.7 608 448L608 288C608 270.3 593.7 256 576 256C558.3 256 544 270.3 544 288L544 370.7L374.6 201.3C362.1 188.8 341.8 188.8 329.3 201.3L224 306.7L86.6 169.4C74.1 156.9 53.8 156.9 41.3 169.4C28.8 181.9 28.8 202.2 41.3 214.7L201.3 374.7C213.8 387.2 234.1 387.2 246.6 374.7L352 269.3L498.7 416L416 416z"/></svg>                    </div>
                </div>
            </div>

            <div class="card-details">
                <p class="card-details-value trend-up financialValue">₱<span id="netProfit"></span></p>
                <p class="card-details-description financialValue"><span id="netProfitStatement"></span>% profit margin</p>
            </div>
        </div>
    </div>

    <div class="dashboard-fin-over-con">
        <!-- ON-GOING DESIGN PA TO  -->
        <div class="dashboard-fin-over-header">
            <p class="dashboard-fin-over-head">Financial Overview</p>
            <p class="dashboard-fin-over-description">Monthly income and expenses comparison</p>
        </div>

        <!-- GRAPH DAPAT DITO -->
        <div class="pie-graph" id="pieGraphIncExpComp">

        </div>

        <div class="line-graph" id="lineGraphIncExpComp">

        </div>

    </div>

    <div class="dashboard-exp-break-cat-con">
        <div class="dashboard-exp-break-cat-header">
            <p class="dashboard-exp-break-cat-head">Expense Breakdown by Category</p>
            <p class="dashboard-exp-break-cat-description">Total expenses by category</p>
        </div>
        
        <!-- GRAPH TO -->
        <div class="bar-graph" id="barGraph">
            
        </div>

    </div>

</div>